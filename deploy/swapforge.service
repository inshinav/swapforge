[Unit]
Description=SwapForge — Seedance subject-swap prompt generator (INSHIN LAB)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/swapforge-current/server
EnvironmentFile=/etc/swapforge.env
EnvironmentFile=-/etc/swapforge-release.env
ExecStart=/usr/bin/node /opt/swapforge-current/server/dist/index.js
Restart=on-failure
RestartSec=5
TimeoutStopSec=120
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
StateDirectory=swapforge
ReadWritePaths=/var/lib/swapforge
UMask=0077

[Install]
WantedBy=multi-user.target
